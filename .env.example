# OSIRIS Situational Dashboard, environment configuration
#
# EVERY API key here is OPTIONAL. The dashboard runs keyless: each layer falls
# back to keyless, static, or empty behavior when its key is absent.
#
# Cost tags:
#   [FREE]      no cost, just register
#   [FREE tier] free plan available, paid upgrades for higher limits
#   [PAID]      paid / commercial only (a free fallback is noted where one exists)
#
# Security: these key-using proxy routes have NO auth or rate limiting. Keep the
# instance LAN-only. An internet-exposed instance lets anyone burn your quotas.


# ===========================================================
# MAP LAYER KEYS
# ===========================================================

# Aviation layer (live aircraft positions).  [FREE]
# Get it: https://opensky-network.org  (Account > API clients, OAuth2 credentials)
# Without: anonymous OpenSky access, heavily rate-limited.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# NASA FIRMS active-fire layer.  [FREE]
# Get it: https://firms.modaps.eosdis.nasa.gov/api/map_key/
# Without: the fires layer is empty.
FIRMS_MAP_KEY=
FIRMS_SOURCES=VIIRS_NOAA20_NRT,VIIRS_SNPP_NRT,MODIS_NRT
FIRMS_DAY_RANGE=1

# Live maritime AIS layer (vessel positions).  [FREE]
# Get it: https://aisstream.io  (free API key)
# Without: the maritime layer stays empty.
AISSTREAM_API_KEY=
AISSTREAM_COLLECT_MS=6500
AISSTREAM_MAX_ITEMS=120

# Satellite positions in the NOAA Space Weather layer.  [FREE tier]
# Get it: https://www.n2yo.com/api/  (register, free tier with hourly limits)
# Without a key: satellites still appear via keyless CelesTrak orbital elements
# propagated with a two-body model (APPROXIMATE positions). Set this for precise
# N2YO positions. N2YO_SATELLITE_IDS/MAX apply to both sources.
N2YO_API_KEY=
N2YO_SATELLITE_IDS=25544,48274,43013,37849,28654,33591,41866,43226
N2YO_MAX_SATELLITES=12
N2YO_OBSERVER_LAT=0
N2YO_OBSERVER_LON=0
N2YO_OBSERVER_ALT_M=0

# Conflict events layer (UCDP GED — curated, death-counted armed conflict).  [FREE tier]
# Get it: https://ucdp.uu.se  (register for a free API access token)
# Without: the "Conflict (UCDP)" layer is empty (GDELT already provides keyless
# conflict coverage). UCDP_VERSION/UCDP_MAX_ITEMS tune the dataset + cap.
UCDP_ACCESS_TOKEN=
UCDP_VERSION=25.1
UCDP_MAX_ITEMS=500

# Live News layer.  [FREE tier]
# Get it: https://newsapi.org  (free developer plan is non-commercial; paid for production)
# Without: the news layer falls back to the static channel list.
NEWSAPI_KEY=
NEWSAPI_QUERY=(sanctions OR conflict OR cyber OR earthquake OR wildfire OR aviation OR maritime)
NEWSAPI_LANGUAGE=en
NEWSAPI_MAX_ITEMS=40


# ===========================================================
# RECON / INTEL KEYS  (Recon panel)
# ===========================================================

# Cyber CVE search (NVD).  [FREE]
# Get it: https://nvd.nist.gov/developers/request-an-api-key
# Without: still works keyless, but NVD throttles unkeyed requests hard.
NVD_API_KEY=

# VulnCheck exploited-CVE intel (Cyber tab: search "vulncheck").  [FREE tier]
# Get it: https://vulncheck.com  (free community API token)
# Without: the "vulncheck" keyword reports "not configured"; "kev"/keyword search
# still works keyless. Adds exploit/weaponization data beyond CISA KEV.
VULNCHECK_API_TOKEN=

# IP reputation in the Intel tab (AbuseIPDB).  [FREE tier]
# Get it: https://www.abuseipdb.com  (free ~1k checks/day; paid for more)
# Without: the AbuseIPDB source reports "not configured".
ABUSEIPDB_API_KEY=
ABUSEIPDB_MAX_AGE_DAYS=90

# IP context in the Intel tab (GreyNoise).  [FREE]
# Get it: https://www.greynoise.io  (free Community API key; enterprise is paid)
# Without: the free community endpoint is still queried keyless (limited fields).
GREYNOISE_API_KEY=

# abuse.ch Auth-Key: ThreatFox (IOC search) + URLhaus (malicious-URL host lookup)
# in the Intel-tab IP lookup, and MalwareBazaar (file-hash lookup).  [FREE tier]
# Get it: https://auth.abuse.ch  (one free Auth-Key works for all abuse.ch APIs)
# Without: ThreatFox + URLhaus + MalwareBazaar report "not configured" (Feodo
# Tracker C2 flagging still works keyless). NOTE: abuse.ch APIs now REQUIRE this
# key (401 without).
ABUSE_CH_AUTH_KEY=

# IP / domain / URL intel in the Intel tab (VirusTotal).  [FREE tier]
# Get it: https://www.virustotal.com  (free public key ~4 req/min; paid premium)
# Without: the VirusTotal lookups report "not configured".
VIRUSTOTAL_API_KEY=

# URLScan.io domain search (Intel-tab domain lookup) — OPTIONAL higher-quota key.
# Get it: https://urlscan.io/user/profile/  (free account issues an API key)
# Without: URLScan is still queried KEYLESS at the low anonymous rate limit; with
# the key it sends the API-Key header for a higher rate limit + a larger result
# window. Purely additive — never becomes required.
URLSCAN_API_KEY=

# GitHub API (Entity tab "GitHub (username)" lookup).  [OPTIONAL]
# Get it: https://github.com/settings/tokens  (a fine-grained or classic token,
# no scopes needed for public data).
# Without: GitHub is queried KEYLESS at 60 requests/hour; the token raises that to
# 5000/hour. Purely additive — never becomes required.
GITHUB_TOKEN=

# Hosted OpenSanctions API (Sanctions search + WHOIS name cross-check).  [PAID]
# Get it: https://www.opensanctions.org  (commercial API license)
# Without: the app uses its free local OFAC / UN / UK / EU feed mirror instead.
OPENSANCTIONS_API_KEY=
SANCTIONS_DISPLAY_MODE=grouped
SANCTIONS_MAX_GROUPS=180
SANCTIONS_MAX_ITEMS=500


# ===========================================================
# KEYLESS LAYER CONFIG  (no key required)
# ===========================================================

# NGA World Port Index cap (ports layer is keyless).
PORTS_MAX_ITEMS=1200

# GDELT global-events layer cap (keyless). Reads GDELT's static Events file every
# 15 min and renders the most press-covered georeferenced events, capped here.
GDELT_MAX_ITEMS=500

# NWS severe-weather alerts layer cap (keyless). Renders US warning polygons that
# have real geometry (most zone-only alerts are skipped).
NWS_MAX_ITEMS=200

# Cloudflare Radar internet-outage layer.  [FREE tier]
# Get it: https://dash.cloudflare.com  (create an API token with Radar read access)
# Without: the "Cloudflare Radar" layer is empty (IODA covers internet outages
# keyless). Cloudflare adds the outage CAUSE (government-directed, power, cable).
CLOUDFLARE_API_TOKEN=

# Telegram OSINT public-preview channels (keyless, reads public web previews only).
OSIRIS_TELEGRAM_CHANNELS=disclosetv,Faytuks,CIG_telegram,BellumActaNews,ClashReport,AuroraIntel,liveukraine_media,wartranslated,rybar,ukrainenowenglish,KyivIndependent_official,DeepStateUA,operativnoZSU,United24media,pravdaGerashchenko_en,DDGeopolitics,intelslava,Slavyangrad,milinfolive,Middle_East_Spectator,MiddleEastEye_TG,QudsNen,LebUpdate,israelwarroom,SyriawatanNews,PressTV,AlManarEnglish,AfricaIntel,HornObserver,TaiwanNews,Focus_Taiwan,KoreaHerald,nexta_live,nexta_tv,babel,Flash_news_ua,BNONews,Breaking911,TheCradleMedia,insiderpaper
OSIRIS_TELEGRAM_MAX_CHANNELS=50


# ===========================================================
# SERVER / NETWORK
# ===========================================================

# Network binding. Defaults to 127.0.0.1 for local dev; the Docker image and
# compose file set HOST=0.0.0.0 so the container is reachable on the LAN.
HOST=127.0.0.1
PORT=4173


# ===========================================================
# HISTORICAL PERSISTENCE  (optional)
# ===========================================================

# Durable event history via built-in node:sqlite (zero npm deps). UNSET =
# disabled: OSIRIS behaves exactly as it does without it (in-memory only, resets
# on restart). Set to a writable path to enable "what changed since X", trends,
# and survival across restart. In Docker this is set by docker-compose.prod.yml
# to /app/data/osiris.db on a named volume — leave it unset for local dev unless
# you want a local store (e.g. ./data/osiris.db).
OSIRIS_DB_PATH=

# CSV allowlist of layers to persist. Only live, event-shaped, stable-id,
# low-volume layers are sensible here; kinematic (aviation/maritime) and static
# (ports/cctv) layers are intentionally excluded.
OSIRIS_PERSIST_LAYERS=seismic,weather,cyber,news,conflict,telegram

# Prune closed events older than this many days (runs on startup + daily).
# Active events are never pruned.
OSIRIS_RETENTION_DAYS=90


# ===========================================================
# ALERTING  (optional)
# ===========================================================

# Slack Incoming Webhook. When set, OSIRIS posts a message whenever an upstream
# source starts failing — rate-limits (HTTP 429/403, e.g. your server IP being
# throttled) are tagged 🚫, other errors ⚠️ — and a ✅ note when it recovers.
# Without: no alerts (failures still show in the /api/health panel as today).
# Get it: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Minimum gap between repeat alerts for the same source, in ms (default 15 min).
# A source that stays down alerts once per window instead of every poll cycle.
ALERT_COOLDOWN_MS=900000

# Optional noise filter. When truthy (1/true/yes/on), ONLY rate-limit failures
# (HTTP 429/403) raise a Slack alert; transient upstream 5xx/network/timeout
# errors are suppressed. Off by default (every failure alerts, as today).
ALERT_RATE_LIMIT_ONLY=


# ===========================================================
# HUMANITARIAN / INFRASTRUCTURE  (optional)
# ===========================================================

# ReliefWeb (UN OCHA) humanitarian disasters. API v1 was decommissioned (HTTP
# 410) and v2 rejects unregistered callers ("not an approved appname"), so this
# is optional-keyed: set it to an appname registered at apidoc.reliefweb.int.
# Without: the Humanitarian layer is empty and flagged in the layer list; GDACS
# still provides keyless disaster coverage.
RELIEFWEB_APPNAME=

# Max ReliefWeb disaster records per fetch (default 200).
RELIEFWEB_MAX_ITEMS=

# OpenStreetMap Overpass endpoint for the Infrastructure layer (substations +
# communications towers). Keyless. Override to point at your own Overpass
# instance if the public one rate-limits you (HTTP 429).
OVERPASS_URL=

# Max viewport area in square degrees before the Infrastructure layer refuses to
# query (default 12). The layer is viewport-scoped so a zoomed-out map does not
# issue a query that can only time out.
OVERPASS_MAX_AREA=

# Max infrastructure features per fetch, split across feature types (default 400).
OVERPASS_MAX_ITEMS=


# ===========================================================
# ALERT RULES  (optional; requires OSIRIS_DB_PATH)
# ===========================================================

# Geofence + keyword alert rules. See config/alert-rules.example.json for the
# shape and docs/PLAN-alert-rules.md for the design. The live file is gitignored
# because rules encode what you are watching. A missing file simply means
# alerting is off; the file is re-read whenever its mtime changes, no restart.
# Requires OSIRIS_DB_PATH: dedupe lives in the store, so an entity alerts exactly
# once per rule, permanently, across restarts.
OSIRIS_ALERT_RULES_PATH=./config/alert-rules.json

# Set to 1 to evaluate rules and log what WOULD fire without sending or
# recording anything. Run this after every rule edit: it is the only way to find
# out that a rule is silently inert (e.g. minSeverity 4 on a layer whose
# severity is a constant 3 validates fine and then never matches).
OSIRIS_ALERT_DRY_RUN=

# Per-rule hourly cap (default 20). Past it, a rule degrades to a summary line
# rather than emptying itself into the channel.
OSIRIS_ALERT_MAX_PER_HOUR=20


# ===========================================================
# KEYS TO ACQUIRE  —  Group C (key-gated), adapters NOT built yet
# ===========================================================
# Shopping list for docs/TODOS.md "Group C". These vars are COMMENTED OUT because
# nothing reads them yet — each becomes a live placeholder when its adapter is
# built (Cody registers the key → Claude builds the adapter + activates the line →
# Cody pastes the real key → Claude verifies). Registration URLs verified to
# resolve 2026-07-22, but signup flows change — re-check at registration time.
#
# Effort legend:  [instant] self-serve key in minutes  ·  [self-serve] account +
# a few steps  ·  [approval] email/application/manual grant, not instant.

# --- Tier 1 (easy free-reg, high value — get these first) ---

# FRED — St. Louis Fed economic time series → Econ tab.  [instant]
# https://fred.stlouisfed.org/docs/api/api_key.html  (page blocks curl; open in a browser)
# FRED_API_KEY=

# EIA — US/global energy prices, production, stocks → Econ tab.  [instant]
# https://www.eia.gov/opendata/register.php
# EIA_API_KEY=

# OpenAQ — global air-quality stations → air-quality map layer.  [instant]
# https://explore.openaq.org/register
# OPENAQ_API_KEY=

# ACLED — authoritative georeferenced conflict events → makes conflict.json live.  [approval]
# Register + get access granted; ACLED needs BOTH the key and the registered email.
# https://developer.acleddata.com/
# ACLED_API_KEY=
# ACLED_EMAIL=

# AlienVault OTX — threat pulses by indicator → Intel fan-out (today just a pivot link).  [instant]
# https://otx.alienvault.com/  (sign up → API key in Settings)
# OTX_API_KEY=

# --- Tier 2 (self-serve) ---

# OpenCorporates — company registry, officers, jurisdictions → Entity tab.  [approval]
# https://opencorporates.com/api_accounts/new  (API-key application)
# OPENCORPORATES_API_TOKEN=

# Electricity Maps — real-time grid production + carbon intensity by zone.  [self-serve]
# https://api-portal.electricitymaps.com/
# ELECTRICITYMAPS_API_TOKEN=

# ENTSO-E Transparency — EU electricity load/generation/cross-border flows.  [approval]
# Create an account, then email transparency@entsoe.eu to request API access.
# https://transparency.entsoe.eu/
# ENTSOE_API_TOKEN=

# OpenCellID — cell-tower locations (telecom infra + geolocation).  [self-serve]
# https://opencellid.org/register.php
# OPENCELLID_API_KEY=

# HealthMap — real-time disease-outbreak map (multi-source).  [approval]
# API access is by request. https://www.healthmap.org/
# HEALTHMAP_API_KEY=

# WOAH WAHIS — animal/zoonotic disease outbreaks (avian flu, ASF).  [approval]
# https://wahis.woah.org/
# WOAH_API_KEY=

# IFES ElectionGuide — upcoming-elections calendar (flashpoint scheduling).  [approval]
# No clean self-serve API URL — request access via https://www.electionguide.org/
# ELECTIONGUIDE_API_KEY=

# UN Comtrade — international trade flows. Free tier is heavily rate-limited.  [self-serve]
# https://comtradedeveloper.un.org/  (subscribe → primary key)
# COMTRADE_API_KEY=

# Global Forest Watch — deforestation / forest-loss alerts.  [self-serve]
# https://data-api.globalforestwatch.org/  (create an API key)
# GFW_API_KEY=

# World Bank Debarred — firms/individuals barred from WB contracts (entity screening).  [approval]
# Reclassified keyed 2026-07-22: the JSON API needs a WB API-gateway subscription
# key (401 without). Harder — may need approval. https://www.worldbank.org/en/projects-operations/procurement/debarred-firms
# WORLDBANK_DEBARRED_KEY=

# --- Notes (no placeholder) ---
# Full OpenSanctions — ALREADY WIRED: set OPENSANCTIONS_API_KEY above (upgrades the
#   Sanctions search from the bundled OFAC/UN/UK mirror to the hosted API + EU/PEPs).
#   No adapter to build — just add the key. Get it: https://www.opensanctions.org/api/
# GEM (Global Energy Monitor) — NOT a keyed API; data is by dataset download/request.
#   Re-probe before treating it as a key. https://globalenergymonitor.org/
# §14 imagery keys (Copernicus, Landsat, Planet NICFI) are DEFERRED to Group D
#   (need COG tiling first) — do NOT register yet.
